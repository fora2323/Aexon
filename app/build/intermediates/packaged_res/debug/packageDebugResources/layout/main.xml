<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="?colorSurface"
	android:fitsSystemWindows="true"
	android:orientation="vertical"
	android:id="@+id/_main">
	<LinearLayout
		android:id="@+id/toolbar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="10dp"
		android:gravity="center_vertical"
		android:orientation="horizontal">
		<LinearLayout
			android:id="@+id/sub_toolbar"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:layout_weight="1">
			<TextView
				android:id="@+id/title_large"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:paddingLeft="8dp"
				android:paddingTop="8dp"
				android:paddingRight="8dp"
				android:paddingBottom="2dp"
				android:text="@string/tag_home"
				android:textSize="24sp"
				android:textStyle="bold" />
			<TextView
				android:id="@+id/title_medium"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:paddingLeft="8dp"
				android:paddingTop="2dp"
				android:paddingRight="8dp"
				android:paddingBottom="8dp"
				android:text="@string/tag_dec_home"
				android:textSize="14sp" />
		</LinearLayout>
		<ImageView
			android:id="@+id/imageview2"
			android:layout_width="40dp"
			android:layout_height="40dp"
			android:padding="6dp"
			android:src="@drawable/ic_info"
			android:scaleType="centerInside" />
		<ImageView
			android:id="@+id/imageview1"
			android:layout_width="40dp"
			android:layout_height="40dp"
			android:layout_margin="4dp"
			android:padding="6dp"
			android:src="@drawable/ic_power"
			android:scaleType="centerInside" />
	</LinearLayout>
	<androidx.viewpager.widget.ViewPager
		android:id="@+id/viewpager1"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:padding="8dp"
		android:layout_weight="1" />
	<com.aexon.widget.AexonNavigationBar
		android:id="@+id/aexonnavigationbbar1"
		android:layout_width="wrap_content"
		android:layout_height="70dp"
		android:layout_margin="24dp"
		android:padding="6dp"
		android:background="?colorSurfaceContainerHigh"
		android:layout_gravity="center_horizontal|bottom"
		app:ax_elevation="4dp"
		app:ax_menu="@menu/nav_menu_bottom"
		app:ax_itemIconTint="@color/nav_icon_selection"
		app:ax_radius="20dp"
		app:ax_itemThumbColor="?attr/colorSecondaryContainer"
		app:ax_itemRippleColor="?attr/colorControlHighlight" />
</LinearLayout>
