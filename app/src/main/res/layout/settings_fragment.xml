<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/root_view"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<ScrollView
		android:id="@+id/vscroll1"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:scrollbars="none">
		<LinearLayout
			android:id="@+id/container"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="15dp"
			android:gravity="center_horizontal"
			android:orientation="vertical">
			<com.aexon.material.cardview.AexonCardView
				android:id="@+id/cardview1"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="12dp"
				android:layout_marginBottom="12dp"
				android:background="@color/colorSurfaceContainer"
				android:orientation="vertical"
				app:boxRadius="14dp">
				<LinearLayout
					android:id="@+id/linear1"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="10dp"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<ImageView
						android:id="@+id/imageview1"
						android:layout_width="35dp"
						android:layout_height="35dp"
						android:padding="6dp"
						android:src="@drawable/ic_aexon"
						android:scaleType="centerCrop" />
					<LinearLayout
						android:id="@+id/linear2"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:padding="4dp"
						android:gravity="center_vertical"
						android:orientation="vertical"
						android:layout_weight="1">
						<TextView
							android:id="@+id/textview1"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:paddingLeft="3dp"
							android:paddingTop="3dp"
							android:paddingRight="3dp"
							android:paddingBottom="1dp"
							android:text="Aexon Monitoring"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnSurface"
							android:includeFontPadding="false" />
						<TextView
							android:id="@+id/textview2"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:paddingLeft="3dp"
							android:paddingTop="1dp"
							android:paddingRight="3dp"
							android:paddingBottom="3dp"
							android:text="Monitor Aexon status in real-time so that Aexon optimization features can run optimally"
							android:textSize="12sp"
							android:textColor="@color/colorOnSurfaceVariant"
							android:includeFontPadding="false" />
					</LinearLayout>
					<com.aexon.material.aexonswitch.AexonSwitch
						android:id="@+id/switch1"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:paddingLeft="8dp"
						android:paddingTop="8dp"
						android:paddingBottom="8dp"
						android:textSize="12sp" />
				</LinearLayout>
			</com.aexon.material.cardview.AexonCardView>
			<com.aexon.material.cardview.AexonCardView
				android:id="@+id/cardview2"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="@color/colorSurfaceContainer"
				android:orientation="vertical"
				app:boxRadius="14dp">
				<LinearLayout
					android:id="@+id/linear3"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<LinearLayout
						android:id="@+id/linear4"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="10dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/imageview3"
							android:layout_width="35dp"
							android:layout_height="35dp"
							android:padding="7dp"
							android:src="@drawable/ic_data_usage"
							android:scaleType="centerCrop" />
						<LinearLayout
							android:id="@+id/linear6"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:padding="4dp"
							android:gravity="center_vertical"
							android:orientation="vertical"
							android:layout_weight="1">
							<TextView
								android:id="@+id/textview5"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingLeft="3dp"
								android:paddingTop="3dp"
								android:paddingRight="3dp"
								android:paddingBottom="1dp"
								android:text="Apps Focus"
								android:textSize="16sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurface"
								android:includeFontPadding="false" />
							<TextView
								android:id="@+id/textview6"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingLeft="3dp"
								android:paddingTop="1dp"
								android:paddingRight="3dp"
								android:paddingBottom="3dp"
								android:text="Keep 2 apps active in the background, stop the rest to save RAM &amp; battery"
								android:textSize="12sp"
								android:textColor="@color/colorOnSurfaceVariant"
								android:includeFontPadding="false" />
						</LinearLayout>
						<com.aexon.material.aexonswitch.AexonSwitch
							android:id="@+id/switch3"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:paddingLeft="8dp"
							android:paddingTop="8dp"
							android:paddingBottom="8dp"
							android:textSize="12sp" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear5"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="12dp"
						android:orientation="vertical"
						android:visibility="gone">
						<com.aexon.material.cardview.AexonCardView
							android:id="@+id/cardview6"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginBottom="4dp"
							android:background="@color/colorSurfaceContainerLow"
							android:orientation="horizontal"
							app:boxRadius="8dp">
							<LinearLayout
								android:id="@+id/linear7"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:paddingLeft="8dp"
								android:paddingTop="6dp"
								android:paddingRight="8dp"
								android:paddingBottom="6dp"
								android:gravity="center_vertical"
								android:orientation="horizontal">
								<com.aexon.material.edittext.AexonEditText
									android:id="@+id/edittext1"
									android:layout_width="0dp"
									android:layout_height="wrap_content"
									android:padding="8dp"
									android:background="@android:color/transparent"
									android:textSize="13sp"
									android:textStyle="bold"
									android:textColor="@color/colorOnSurface"
									android:hint="Focus Package 1"
									android:textColorHint="@color/colorOnSurfaceVariant"
									android:layout_weight="1"
									app:aexon_mode="filled" />
								<ImageView
									android:id="@+id/imageview4"
									android:layout_width="30dp"
									android:layout_height="30dp"
									android:padding="5dp"
									android:src="@drawable/ic_restart"
									android:scaleType="centerCrop" />
							</LinearLayout>
						</com.aexon.material.cardview.AexonCardView>
						<com.aexon.material.cardview.AexonCardView
							android:id="@+id/cardview7"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="4dp"
							android:background="@color/colorSurfaceContainerLow"
							android:orientation="horizontal"
							app:boxRadius="8dp">
							<LinearLayout
								android:id="@+id/linear8"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:paddingLeft="8dp"
								android:paddingTop="6dp"
								android:paddingRight="8dp"
								android:paddingBottom="6dp"
								android:gravity="center_vertical"
								android:orientation="horizontal">
								<com.aexon.material.edittext.AexonEditText
									android:id="@+id/edittext2"
									android:layout_width="0dp"
									android:layout_height="wrap_content"
									android:padding="8dp"
									android:background="@android:color/transparent"
									android:textSize="13sp"
									android:textStyle="bold"
									android:textColor="@color/colorOnSurface"
									android:hint="Focus Package 2"
									android:textColorHint="@color/colorOnSurfaceVariant"
									android:layout_weight="1"
									app:aexon_mode="filled" />
								<ImageView
									android:id="@+id/imageview5"
									android:layout_width="30dp"
									android:layout_height="30dp"
									android:padding="5dp"
									android:src="@drawable/ic_restart"
									android:scaleType="centerCrop" />
							</LinearLayout>
						</com.aexon.material.cardview.AexonCardView>
					</LinearLayout>
				</LinearLayout>
			</com.aexon.material.cardview.AexonCardView>
			<com.aexon.material.cardview.AexonCardView
				android:id="@+id/cardview3"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="12dp"
				android:layout_marginBottom="12dp"
				android:background="@color/colorSurfaceContainer"
				android:orientation="vertical"
				app:boxRadius="14dp">
				<LinearLayout
					android:id="@+id/linear9"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="10dp"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<ImageView
						android:id="@+id/imageview2"
						android:layout_width="35dp"
						android:layout_height="35dp"
						android:padding="7dp"
						android:src="@drawable/ic_snippet_folder"
						android:scaleType="centerCrop" />
					<LinearLayout
						android:id="@+id/linear11"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:padding="4dp"
						android:gravity="center_vertical"
						android:orientation="vertical"
						android:layout_weight="1">
						<TextView
							android:id="@+id/textview3"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:paddingLeft="3dp"
							android:paddingTop="3dp"
							android:paddingRight="3dp"
							android:paddingBottom="1dp"
							android:text="Clear cache smartly"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnSurface"
							android:includeFontPadding="false" />
						<TextView
							android:id="@+id/textview4"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:paddingLeft="3dp"
							android:paddingTop="1dp"
							android:paddingRight="3dp"
							android:paddingBottom="3dp"
							android:text="Automatically purge cache if folders are recreated."
							android:textSize="12sp"
							android:textColor="@color/colorOnSurfaceVariant"
							android:includeFontPadding="false" />
					</LinearLayout>
					<com.aexon.material.aexonswitch.AexonSwitch
						android:id="@+id/switch2"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:paddingLeft="8dp"
						android:paddingTop="8dp"
						android:paddingBottom="8dp"
						android:textSize="12sp" />
				</LinearLayout>
			</com.aexon.material.cardview.AexonCardView>
			<com.aexon.material.cardview.AexonCardView
				android:id="@+id/cardview4"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="@color/colorSurfaceContainer"
				android:orientation="vertical"
				app:boxRadius="14dp">
				<LinearLayout
					android:id="@+id/linear12"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="10dp"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<ImageView
						android:id="@+id/imageview6"
						android:layout_width="35dp"
						android:layout_height="35dp"
						android:padding="7dp"
						android:src="@drawable/ic_folder_delete"
						android:scaleType="centerCrop" />
					<LinearLayout
						android:id="@+id/linear13"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="4dp"
						android:gravity="center_vertical"
						android:orientation="vertical"
						android:layout_weight="1">
						<TextView
							android:id="@+id/textview7"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:paddingLeft="3dp"
							android:paddingTop="3dp"
							android:paddingRight="3dp"
							android:paddingBottom="1dp"
							android:text="Reset Aexon"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnSurface"
							android:includeFontPadding="false" />
						<TextView
							android:id="@+id/textview8"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:paddingLeft="3dp"
							android:paddingTop="1dp"
							android:paddingRight="3dp"
							android:paddingBottom="3dp"
							android:text="This action will deactivate and remove all your plugins"
							android:textSize="12sp"
							android:textColor="@color/colorOnSurfaceVariant"
							android:includeFontPadding="false" />
					</LinearLayout>
				</LinearLayout>
			</com.aexon.material.cardview.AexonCardView>
			<com.aexon.material.cardview.AexonCardView
				android:id="@+id/cardview5"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="12dp"
				android:layout_marginBottom="70dp"
				android:background="@color/colorSurfaceContainer"
				android:orientation="vertical"
				app:boxRadius="14dp">
				<LinearLayout
					android:id="@+id/linear14"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">
					<LinearLayout
						android:id="@+id/linear15"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="10dp"
						android:paddingTop="10dp"
						android:paddingRight="10dp"
						android:paddingBottom="5dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/imageview7"
							android:layout_width="35dp"
							android:layout_height="35dp"
							android:padding="6dp"
							android:src="@drawable/ic_text"
							android:scaleType="centerCrop" />
						<TextView
							android:id="@+id/textview9"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="6dp"
							android:text="Settings Editor"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnSurface"
							android:includeFontPadding="false" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear16"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="10dp"
						android:paddingTop="5dp"
						android:paddingRight="10dp"
						android:paddingBottom="5dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/imageview8"
							android:layout_width="35dp"
							android:layout_height="35dp"
							android:padding="7dp"
							android:src="@drawable/ic_palette"
							android:scaleType="centerCrop" />
						<TextView
							android:id="@+id/textview10"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="6dp"
							android:text="Appearance"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnSurface"
							android:includeFontPadding="false" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear17"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="10dp"
						android:paddingTop="5dp"
						android:paddingRight="10dp"
						android:paddingBottom="10dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/imageview9"
							android:layout_width="35dp"
							android:layout_height="35dp"
							android:padding="6dp"
							android:src="@drawable/ic_bug_report"
							android:scaleType="centerCrop" />
						<TextView
							android:id="@+id/textview11"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="6dp"
							android:text="Developer"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnSurface"
							android:includeFontPadding="false" />
					</LinearLayout>
				</LinearLayout>
			</com.aexon.material.cardview.AexonCardView>
		</LinearLayout>
	</ScrollView>
</LinearLayout>