<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fitsSystemWindows="true"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear12"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical"
		android:fitsSystemWindows="true">
		<LinearLayout
			android:id="@+id/toolbar"
			android:layout_width="match_parent"
			android:layout_height="56dp"
			android:paddingLeft="6dp"
			android:background="@color/colorSurface"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/imageview1"
				android:layout_width="40dp"
				android:layout_height="40dp"
				android:padding="8dp"
				android:src="@drawable/ic_arrow_back"
				android:scaleType="centerInside"
				android:layout_gravity="center_vertical" />
			<TextView
				android:id="@+id/textview1"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginLeft="4dp"
				android:gravity="center_vertical"
				android:text="Activation"
				android:textSize="22sp"
				android:textStyle="bold"
				android:textColor="@color/colorOnSurface"
				android:includeFontPadding="false" />
		</LinearLayout>
		<ScrollView
			android:id="@+id/vscroll1"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:background="@color/colorSurface"
			android:scrollbars="none">
			<LinearLayout
				android:id="@+id/linear1"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:padding="15dp"
				android:orientation="vertical">
				<com.aexon.material.cardview.AexonCardView
					android:id="@+id/cardview1"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@color/colorSurfaceContainer"
					android:orientation="vertical"
					app:boxRadius="14dp">
					<LinearLayout
						android:id="@+id/linear10"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="12dp"
						android:paddingTop="15dp"
						android:paddingRight="12dp"
						android:paddingBottom="16dp"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/linear11"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="6dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview6"
								android:layout_width="35dp"
								android:layout_height="35dp"
								android:padding="5dp"
								android:src="@drawable/ic_shizuku"
								android:scaleType="centerCrop" />
							<TextView
								android:id="@+id/textview2"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingLeft="12dp"
								android:paddingTop="8dp"
								android:paddingRight="8dp"
								android:paddingBottom="8dp"
								android:text="@string/tag_cnect_shizuku"
								android:textSize="16sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurface"
								android:includeFontPadding="false" />
						</LinearLayout>
						<TextView
							android:id="@+id/textview3"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="4dp"
							android:paddingLeft="8dp"
							android:paddingTop="12dp"
							android:paddingRight="8dp"
							android:paddingBottom="10dp"
							android:text="@string/dec_shizuku"
							android:textSize="12sp"
							android:textColor="@color/colorOnSurfaceVariant"
							android:includeFontPadding="false" />
						<com.aexon.material.button.AexonButton
							android:id="@+id/pair"
							android:layout_width="wrap_content"
							android:layout_height="38dp"
							android:layout_marginLeft="6dp"
							android:layout_marginBottom="8dp"
							android:paddingLeft="18dp"
							android:paddingTop="4dp"
							android:paddingRight="18dp"
							android:paddingBottom="4dp"
							android:text="@string/tag_btn_shizuku"
							android:textSize="13sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnPrimary"
							app:cornerRadius="100dp"
							app:icon="@drawable/ic_shizuku"
							app:iconGravity="start"
							app:iconPadding="10dp"
							app:iconTint="@color/colorOnPrimary"
							app:iconSize="18dp"
							app:buttonColor="@color/colorPrimary" />
						<com.aexon.material.button.AexonButton
							android:id="@+id/start"
							android:layout_width="wrap_content"
							android:layout_height="38dp"
							android:layout_marginLeft="6dp"
							android:paddingLeft="18dp"
							android:paddingTop="4dp"
							android:paddingRight="18dp"
							android:paddingBottom="4dp"
							android:text="Start"
							android:textSize="13sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnPrimary"
							app:cornerRadius="100dp"
							app:icon="@drawable/ic_play"
							app:iconGravity="start"
							app:iconPadding="2dp"
							app:iconTint="@color/colorOnPrimary"
							app:iconSize="18dp"
							app:buttonColor="@color/colorPrimary" />
					</LinearLayout>
				</com.aexon.material.cardview.AexonCardView>
				<com.aexon.material.cardview.AexonCardView
					android:id="@+id/cardview2"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="10dp"
					android:layout_marginBottom="10dp"
					android:background="@color/colorSurfaceContainer"
					android:orientation="vertical"
					app:boxRadius="14dp">
					<LinearLayout
						android:id="@+id/linear5"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="12dp"
						android:paddingTop="15dp"
						android:paddingRight="12dp"
						android:paddingBottom="16dp"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/linear3"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="6dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview2"
								android:layout_width="35dp"
								android:layout_height="35dp"
								android:padding="5dp"
								android:src="@drawable/ic_computer"
								android:scaleType="centerCrop" />
							<TextView
								android:id="@+id/textview4"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingLeft="12dp"
								android:paddingTop="8dp"
								android:paddingRight="8dp"
								android:paddingBottom="8dp"
								android:text="Start connecting to the computer"
								android:textSize="16sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurface"
								android:includeFontPadding="false" />
						</LinearLayout>
						<TextView
							android:id="@+id/textview5"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="4dp"
							android:layout_marginBottom="8dp"
							android:padding="8dp"
							android:text="For devices without root, you need to use adb to start Aexon (requires computer connection). This process needs to be repeated every time the device is restarted"
							android:textSize="12sp"
							android:textColor="@color/colorOnSurfaceVariant"
							android:includeFontPadding="false" />
						<com.aexon.material.button.AexonButton
							android:id="@+id/view_cmd"
							android:layout_width="wrap_content"
							android:layout_height="38dp"
							android:layout_marginLeft="6dp"
							android:paddingLeft="18dp"
							android:paddingTop="4dp"
							android:paddingRight="18dp"
							android:paddingBottom="4dp"
							android:text="View command"
							android:textSize="13sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnPrimary"
							app:cornerRadius="100dp"
							app:icon="@drawable/ic_code"
							app:iconGravity="start"
							app:iconPadding="10dp"
							app:iconTint="@color/colorOnPrimary"
							app:iconSize="18dp"
							app:buttonColor="@color/colorPrimary" />
					</LinearLayout>
				</com.aexon.material.cardview.AexonCardView>
				<com.aexon.material.cardview.AexonCardView
					android:id="@+id/cardview3"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@color/colorSurfaceContainer"
					android:orientation="vertical"
					app:boxRadius="14dp">
					<LinearLayout
						android:id="@+id/linear7"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="12dp"
						android:paddingTop="15dp"
						android:paddingRight="12dp"
						android:paddingBottom="16dp"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/linear8"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="6dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview4"
								android:layout_width="35dp"
								android:layout_height="35dp"
								android:padding="5dp"
								android:src="@drawable/ic_security"
								android:scaleType="centerCrop" />
							<TextView
								android:id="@+id/textview6"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingLeft="12dp"
								android:paddingTop="8dp"
								android:paddingRight="8dp"
								android:paddingBottom="8dp"
								android:text="Start (for rooted devices)"
								android:textSize="16sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurface"
								android:includeFontPadding="false" />
						</LinearLayout>
						<TextView
							android:id="@+id/textview7"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="4dp"
							android:layout_marginBottom="8dp"
							android:paddingLeft="8dp"
							android:paddingTop="8dp"
							android:paddingRight="8dp"
							android:paddingBottom="12dp"
							android:text="@string/tag_dec_rooted"
							android:textSize="12sp"
							android:textColor="@color/colorOnSurfaceVariant"
							android:includeFontPadding="false" />
						<com.aexon.material.button.AexonButton
							android:id="@+id/start_root"
							android:layout_width="wrap_content"
							android:layout_height="38dp"
							android:layout_marginLeft="6dp"
							android:paddingLeft="18dp"
							android:paddingTop="4dp"
							android:paddingRight="18dp"
							android:paddingBottom="4dp"
							android:text="Start"
							android:textSize="13sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnPrimary"
							app:cornerRadius="100dp"
							app:icon="@drawable/ic_play"
							app:iconGravity="start"
							app:iconPadding="2dp"
							app:iconTint="@color/colorOnPrimary"
							app:iconSize="18dp"
							app:buttonColor="@color/colorPrimary" />
					</LinearLayout>
				</com.aexon.material.cardview.AexonCardView>
			</LinearLayout>
		</ScrollView>
	</LinearLayout>
</LinearLayout>
