<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/root_view"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<ScrollView
		android:id="@+id/vscroll1"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:scrollbars="none">
		<LinearLayout
			android:id="@+id/container"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="15dp"
			android:orientation="vertical">
			<com.aexon.material.cardview.AexonCardView
				android:id="@+id/cardview1"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="4dp"
				android:layout_marginBottom="12dp"
				android:background="@color/colorPrimary"
				android:orientation="vertical"
				app:boxRadius="14dp"
				android:clipChildren="false"
				android:clipToPadding="false">
				<LinearLayout
					android:id="@+id/linear3"
					android:layout_width="match_parent"
					android:layout_height="150dp"
					android:padding="10dp"
					android:orientation="horizontal">
					<LinearLayout
						android:id="@+id/linear24"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:padding="8dp"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/linear4"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<TextView
								android:id="@+id/textview1"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingLeft="2dp"
								android:paddingTop="2dp"
								android:paddingRight="8dp"
								android:paddingBottom="2dp"
								android:text="@string/tag_not_running"
								android:textSize="18sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnPrimary"
								android:layout_gravity="bottom"
								android:includeFontPadding="false" />
							<TextView
								android:id="@+id/textview3"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingLeft="8dp"
								android:paddingTop="6dp"
								android:paddingRight="8dp"
								android:paddingBottom="6dp"
								android:background="@color/colorPrimaryDark"
								android:text="Shell"
								android:textSize="10sp"
								android:textColor="@color/colorOnSurface" />
						</LinearLayout>
						<TextView
							android:id="@+id/textview2"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="2dp"
							android:text="@string/tag_aexon_not_run"
							android:textSize="14sp"
							android:textColor="@color/colorOnPrimary"
							android:includeFontPadding="false" />
						<LinearLayout
							android:id="@+id/linear26"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:gravity="bottom"
							android:orientation="vertical">
							<TextView
								android:id="@+id/tmp_timer"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:text="T+00:00:00"
								android:textSize="14sp"
								android:textColor="@color/colorOnPrimary" />
						</LinearLayout>
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear25"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:padding="12dp"
						android:gravity="center_vertical"
						android:orientation="vertical">
						<ImageView
							android:id="@+id/imageview1"
							android:layout_width="80dp"
							android:layout_height="80dp"
							android:padding="12dp"
							android:background="@color/colorPrimaryDark"
							android:src="@drawable/ic_aexon"
							android:scaleType="centerCrop"
							android:layout_gravity="right|bottom" />
					</LinearLayout>
				</LinearLayout>
			</com.aexon.material.cardview.AexonCardView>
			<LinearLayout
				android:id="@+id/sub_container"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="12dp"
				android:orientation="horizontal">
				<com.aexon.material.cardview.AexonCardView
					android:id="@+id/cardview2"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginRight="6dp"
					android:background="@color/colorSurfaceContainer"
					android:orientation="vertical"
					android:layout_weight="1"
					app:boxRadius="14dp"
					android:clipChildren="false"
					android:clipToPadding="false">
					<LinearLayout
						android:id="@+id/linear6"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:padding="10dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/imageview2"
							android:layout_width="35dp"
							android:layout_height="35dp"
							android:padding="5dp"
							android:src="@drawable/ic_extension"
							android:scaleType="centerCrop"
							android:layout_gravity="center_vertical" />
						<LinearLayout
							android:id="@+id/linear7"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:orientation="vertical"
							android:layout_weight="1">
							<TextView
								android:id="@+id/textview4"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:paddingLeft="2dp"
								android:paddingTop="2dp"
								android:paddingRight="2dp"
								android:paddingBottom="3dp"
								android:text="Plugins"
								android:textSize="18sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurface" />
							<TextView
								android:id="@+id/textview5"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:paddingLeft="2dp"
								android:paddingTop="3dp"
								android:paddingRight="2dp"
								android:paddingBottom="2dp"
								android:text="0"
								android:textSize="15sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurfaceVariant" />
						</LinearLayout>
						<ImageView
							android:id="@+id/imageview3"
							android:layout_width="28dp"
							android:layout_height="28dp"
							android:padding="4dp"
							android:src="@drawable/ic_keyboard_right"
							android:scaleType="centerCrop" />
					</LinearLayout>
				</com.aexon.material.cardview.AexonCardView>
				<com.aexon.material.cardview.AexonCardView
					android:id="@+id/cardview3"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginLeft="6dp"
					android:background="@color/colorSurfaceContainer"
					android:orientation="vertical"
					android:layout_weight="1"
					app:boxRadius="14dp"
					android:clipChildren="false"
					android:clipToPadding="false">
					<LinearLayout
						android:id="@+id/linear9"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:padding="10dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/imageview4"
							android:layout_width="35dp"
							android:layout_height="35dp"
							android:padding="5dp"
							android:src="@drawable/ic_rocket"
							android:scaleType="centerCrop"
							android:layout_gravity="center_vertical" />
						<LinearLayout
							android:id="@+id/linear10"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:orientation="vertical"
							android:layout_weight="1">
							<TextView
								android:id="@+id/textview6"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:paddingLeft="2dp"
								android:paddingTop="2dp"
								android:paddingRight="2dp"
								android:paddingBottom="3dp"
								android:text="Booster"
								android:textSize="18sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurface" />
							<TextView
								android:id="@+id/textview7"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:paddingLeft="2dp"
								android:paddingTop="3dp"
								android:paddingRight="2dp"
								android:paddingBottom="2dp"
								android:text="80%"
								android:textSize="15sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurfaceVariant" />
						</LinearLayout>
						<ImageView
							android:id="@+id/imageview5"
							android:layout_width="28dp"
							android:layout_height="28dp"
							android:padding="4dp"
							android:src="@drawable/ic_keyboard_right"
							android:scaleType="centerCrop" />
					</LinearLayout>
				</com.aexon.material.cardview.AexonCardView>
			</LinearLayout>
			<com.aexon.material.cardview.AexonCardView
				android:id="@+id/cardview4"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="12dp"
				android:background="@color/colorSurfaceContainer"
				android:orientation="vertical"
				app:boxRadius="14dp">
				<LinearLayout
					android:id="@+id/linear12"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="10dp"
					android:orientation="vertical">
					<com.aexon.material.cardview.AexonCardView
						android:id="@+id/cardview5"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:background="@color/colorSurfaceContainerHighest"
						android:orientation="vertical"
						app:boxRadius="14dp">
						<LinearLayout
							android:id="@+id/linear15"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:paddingLeft="6dp"
							android:paddingTop="4dp"
							android:paddingRight="6dp"
							android:paddingBottom="4dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview6"
								android:layout_width="28dp"
								android:layout_height="28dp"
								android:padding="2dp"
								android:src="@drawable/ic_android"
								android:scaleType="centerInside" />
							<TextView
								android:id="@+id/textview8"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:paddingLeft="14dp"
								android:paddingTop="2dp"
								android:paddingBottom="2dp"
								android:text="Android Version"
								android:textSize="12sp"
								android:textColor="@color/colorOnSurfaceVariant"
								android:layout_weight="1" />
							<TextView
								android:id="@+id/textview9"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingRight="10dp"
								android:text="TextView"
								android:textSize="12sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurface"
								android:includeFontPadding="false" />
						</LinearLayout>
					</com.aexon.material.cardview.AexonCardView>
					<com.aexon.material.cardview.AexonCardView
						android:id="@+id/cardview6"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:layout_marginBottom="8dp"
						android:background="@color/colorSurfaceContainerHighest"
						android:orientation="vertical"
						app:boxRadius="14dp">
						<LinearLayout
							android:id="@+id/linear16"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:paddingLeft="6dp"
							android:paddingTop="4dp"
							android:paddingRight="6dp"
							android:paddingBottom="4dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview7"
								android:layout_width="28dp"
								android:layout_height="28dp"
								android:padding="2dp"
								android:src="@drawable/ic_memory"
								android:scaleType="centerCrop" />
							<TextView
								android:id="@+id/textview10"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:paddingLeft="14dp"
								android:text="ABI Supported"
								android:textSize="12sp"
								android:textColor="@color/colorOnSurfaceVariant"
								android:layout_weight="1" />
							<TextView
								android:id="@+id/textview11"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingRight="10dp"
								android:text="arm64-v8a, armeabi-v7a, armeabi"
								android:textSize="12sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurface"
								android:includeFontPadding="false" />
						</LinearLayout>
					</com.aexon.material.cardview.AexonCardView>
					<com.aexon.material.cardview.AexonCardView
						android:id="@+id/cardview7"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:background="@color/colorSurfaceContainerHighest"
						android:orientation="vertical"
						app:boxRadius="14dp">
						<LinearLayout
							android:id="@+id/linear17"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:paddingLeft="6dp"
							android:paddingTop="4dp"
							android:paddingRight="6dp"
							android:paddingBottom="4dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview8"
								android:layout_width="28dp"
								android:layout_height="25dp"
								android:padding="2dp"
								android:src="@drawable/ic_security"
								android:scaleType="centerCrop" />
							<TextView
								android:id="@+id/textview12"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:paddingLeft="14dp"
								android:text="SELinux Context"
								android:textSize="12sp"
								android:textColor="@color/colorOnSurfaceVariant"
								android:layout_weight="1" />
							<TextView
								android:id="@+id/textview13"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingRight="10dp"
								android:text="Unknown"
								android:textSize="12sp"
								android:textStyle="bold"
								android:textColor="@color/colorOnSurface"
								android:includeFontPadding="false" />
						</LinearLayout>
					</com.aexon.material.cardview.AexonCardView>
				</LinearLayout>
			</com.aexon.material.cardview.AexonCardView>
			<com.aexon.material.cardview.AexonCardView
				android:id="@+id/cardview8"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="12dp"
				android:orientation="vertical"
				app:boxRadius="14dp">
				<LinearLayout
					android:id="@+id/linear18"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:padding="10dp"
					android:background="@color/colorSurfaceContainer"
					android:orientation="horizontal">
					<LinearLayout
						android:id="@+id/linear20"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:paddingLeft="10dp"
						android:paddingTop="12dp"
						android:paddingRight="12dp"
						android:paddingBottom="12dp"
						android:orientation="vertical"
						android:layout_weight="1">
						<TextView
							android:id="@+id/textview14"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="2dp"
							android:text="Support Me"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnSurface" />
						<TextView
							android:id="@+id/textview15"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="2dp"
							android:text="@string/tag_dec_support_github"
							android:textSize="12sp"
							android:textColor="@color/colorOnSurfaceVariant" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear21"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:padding="12dp"
						android:gravity="center_horizontal|center_vertical"
						android:orientation="vertical">
						<ImageView
							android:id="@+id/imageview9"
							android:layout_width="35dp"
							android:layout_height="35dp"
							android:padding="8dp"
							android:src="@drawable/ic_open"
							android:scaleType="centerInside" />
					</LinearLayout>
				</LinearLayout>
			</com.aexon.material.cardview.AexonCardView>
			<com.aexon.material.cardview.AexonCardView
				android:id="@+id/cardview9"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="130dp"
				android:orientation="vertical"
				app:boxRadius="14dp">
				<LinearLayout
					android:id="@+id/linear19"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:padding="10dp"
					android:background="@color/colorSurfaceContainer"
					android:orientation="horizontal">
					<LinearLayout
						android:id="@+id/linear22"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:paddingLeft="10dp"
						android:paddingTop="12dp"
						android:paddingRight="12dp"
						android:paddingBottom="12dp"
						android:orientation="vertical"
						android:layout_weight="1">
						<TextView
							android:id="@+id/textview16"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="2dp"
							android:text="Having Trouble\?"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/colorOnSurface" />
						<TextView
							android:id="@+id/textview17"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="2dp"
							android:text="Found a bug or have a suggestion\? Let me know through Telegram or WhatsApp!"
							android:textSize="12sp"
							android:textColor="@color/colorOnSurfaceVariant" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear23"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:padding="12dp"
						android:gravity="center_horizontal|center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/imageview10"
							android:layout_width="35dp"
							android:layout_height="35dp"
							android:layout_marginRight="10dp"
							android:padding="8dp"
							android:src="@drawable/ic_whatsapp"
							android:scaleType="centerInside" />
						<ImageView
							android:id="@+id/imageview11"
							android:layout_width="35dp"
							android:layout_height="35dp"
							android:layout_marginLeft="10dp"
							android:padding="8dp"
							android:src="@drawable/ic_telegram"
							android:scaleType="centerInside" />
					</LinearLayout>
				</LinearLayout>
			</com.aexon.material.cardview.AexonCardView>
		</LinearLayout>
	</ScrollView>
</LinearLayout>